{
  "name": "bunjang-cli",
  "version": "0.1.0",
  "description": "CLI-first Bunjang client for humans and AI agents",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinion05/bunjangcli.git"
  },
  "homepage": "https://github.com/pinion05/bunjangcli#readme",
  "bugs": {
    "url": "https://github.com/pinion05/bunjangcli/issues"
  },
  "keywords": [
    "bunjang",
    "cli",
    "marketplace",
    "playwright",
    "automation"
  ],
  "files": [
    "dist/src/",
    "README.md"
  ],
  "bin": {
    "bunjang-cli": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "pnpm build && vitest run --config tests/e2e/vitest.config.ts",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "playwright": "^1.55.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
